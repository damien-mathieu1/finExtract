DATABASE_URL=postgresql+psycopg://finextract:finextract@postgres:5432/finextract
LOG_LEVEL=INFO

# Required for the SEC EDGAR company search / filing lookup endpoints.
# SEC rejects requests without an identifying User-Agent. Format: "AppName you@example.com"
SEC_EDGAR_USER_AGENT=FinExtract you@example.com

# --- Clerk auth (keys from https://dashboard.clerk.com -> your app -> API Keys) ---
# Backend JWT verification (the API is publicly reachable and validates tokens
# itself). Issuer is the Clerk frontend API URL, e.g. the dev instance:
CLERK_ISSUER=https://your-slug.clerk.accounts.dev
# Optional: comma-separated origins allowed as `azp` claim.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000
# Extraction rows a user may create per UTC day (one filing = 2-3 rows).
DAILY_EXTRACTION_QUOTA=20
# Frontend (Next.js) — docker-compose passes this same file to the frontend
# container, so all Clerk vars live here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
# Local-dev only escape hatch: skip JWT verification entirely.
# AUTH_DISABLED=true
